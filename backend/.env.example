# 复制本文件为 .env 后修改

# 数据库（dev 用 sqlite，prod 改成 mysql+pymysql://user:pass@rds-host/movie_prod）
DATABASE_URL=sqlite:///./dev.db

# JWT 签发密钥（生产必须 openssl rand -hex 32 重生）
JWT_SECRET=dev-secret-please-change-me-in-production-32-chars-min

# 后台超管初始账号（首次 seed 用，之后改密）
SEED_ADMIN_EMAIL=admin@movie.local
SEED_ADMIN_PASSWORD=admin123

# CORS：dev 时 admin-web 跑 5174，App 端调试可能用其它端口
CORS_ALLOW_ORIGINS=http://localhost:5174,http://localhost:3000
