# 复制本文件为 .env 后修改

# 数据库（dev 用 sqlite，prod 改成 mysql+pymysql://user:pass@rds-host/movie_prod）
DATABASE_URL=sqlite:///./dev.db

# JWT 签发密钥（生产必须 openssl rand -hex 32 重生）
JWT_SECRET=dev-secret-please-change-me-in-production-32-chars-min

# 后台超管初始账号（首次 seed 用，之后改密）
SEED_ADMIN_EMAIL=admin@movie.local
SEED_ADMIN_PASSWORD=admin123

# CORS：dev 时 admin-web 跑 5174，App 端调试可能用其它端口
CORS_ALLOW_ORIGINS=http://localhost:5174,http://localhost:3000

# ===== C 端用户 JWT =====
USER_ACCESS_TOKEN_MINUTES=15
USER_REFRESH_TOKEN_DAYS=30

# ===== Google OAuth（dev 留空 = mock 模式接受任何 id_token）=====
GOOGLE_CLIENT_ID=

# ===== Cloudflare Turnstile（dev 留空 = mock 模式接受任何 token）=====
TURNSTILE_SECRET=

# ===== OTP =====
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_PHONE_SECONDS=60
OTP_RATE_LIMIT_PER_IP_PER_5MIN=5
OTP_RATE_LIMIT_PER_DEVICE_PER_DAY=10
# 手机号国家码白名单（PROMPT.md C1 东南亚 + C3 中东/拉美/非洲）
ALLOWED_PHONE_COUNTRY_CODES=+62,+84,+63,+66,+855,+95,+966,+971,+20,+962,+961,+963,+234,+27,+254,+251,+255,+55,+52,+54,+56,+57,+51,+58
