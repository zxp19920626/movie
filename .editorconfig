# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Python (backend) — PEP 8
[*.py]
indent_size = 4
max_line_length = 100

# TypeScript / JavaScript / Vue / JSON / YAML — 2 spaces
[*.{ts,tsx,js,jsx,vue,json,yml,yaml,toml}]
indent_size = 2

# Markdown — 不裁剪行尾（hard line breaks 需要双空格）
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Shell
[*.{sh,bash}]
indent_size = 2

# Makefile 必须用 tab
[Makefile]
indent_style = tab
