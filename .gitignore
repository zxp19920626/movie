.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# ===== Python (backend) =====
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
.uv-cache/
.python-version-local
*.db
*.db-journal
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg-info/
build/

# Backend secrets & local artifacts
backend/.env
backend/dev.db
backend/storage/

# ===== Node (admin-web) =====
node_modules/
dist/
*.tsbuildinfo
.vite/
admin-web/src/auto-imports.d.ts
admin-web/src/components.d.ts
.npm-debug.log
.pnpm-debug.log
yarn-error.log

# ===== Secrets — 永远不许进 Git =====
*.keystore
*.jks
*.p12
*.pem
*.key
.env
.env.local
.env.*.local

# ===== Logs / runtime =====
logs/
*.log
.cache/
tmp/

# Claude Code 本地状态（运行时缓存不进 git）
.claude/*
# 但项目级 Agent/Command 配置 + 流水线状态必须进 git（跨会话恢复 / 团队共享 / 交接保留）
!.claude/agents/
!.claude/commands/
!.claude/runs/
.claude/runs/*/stopped.flag
